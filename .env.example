# Copy this file to .env.local and fill in values. On Vercel: Project → Settings → Environment Variables (same names).

# --- Supabase (required) — from Supabase → Project Settings → API
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# --- App / marketing URLs (used by CTAs and lib/site.js)
# NEXT_PUBLIC_APP_ORIGIN=https://app.findfoundfast.com
# NEXT_PUBLIC_MARKETING_ORIGIN=https://findfoundfast.com
# Optional: legacy single-site URL (used if MARKETING_ORIGIN unset)
# NEXT_PUBLIC_SITE_URL=https://www.findfoundfast.com

# --- Lead notification emails (POST /api/demo) — https://resend.com
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=FindFoundFast <noreply@yourdomain.com>
# LEAD_INBOX_EMAIL=
